FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Repo root flat bo'lgani uchun app/grading/ papkasini shu yerda quramiz
RUN mkdir -p app/grading
COPY main.py app/main.py
COPY __init__.py app/grading/__init__.py
COPY router.py app/grading/router.py
COPY schemas.py app/grading/schemas.py
COPY openai_client.py app/grading/openai_client.py
RUN touch app/__init__.py

ENV PORT=8000
EXPOSE 8000

CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port ${PORT}"]
